#!/usr/bin/env sh
SCRIPT_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"

run_with_python() {
  INTERPRETER="$1"
  shift
  PYTHONPATH="$SCRIPT_DIR${PYTHONPATH:+:$PYTHONPATH}" exec "$INTERPRETER" -m clanker_courts_autoplayer "$@"
}

if [ -n "${PYTHON:-}" ]; then
  run_with_python "$PYTHON" "$@"
fi

if command -v python3 >/dev/null 2>&1 && python3 - <<'PY' >/dev/null 2>&1
import sys
raise SystemExit(0 if sys.version_info >= (3, 11) else 1)
PY
then
  run_with_python python3 "$@"
fi

if command -v uv >/dev/null 2>&1; then
  PYTHONPATH="$SCRIPT_DIR${PYTHONPATH:+:$PYTHONPATH}" \
    exec uv run --quiet --python ">=3.11" python -m clanker_courts_autoplayer "$@"
fi

cat >&2 <<'EOF'
clanker-courts-autoplayer requires Python 3.11+.

Set PYTHON to a compatible interpreter, or install uv and rerun this command.
EOF
exit 1
