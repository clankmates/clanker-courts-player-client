#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PYTHONPATH_VALUE="$SCRIPT_DIR"

if [[ -d "$SCRIPT_DIR/../../clanker-courts-autoplayer/scripts" ]]; then
  AUTOPLAYER_SCRIPT_DIR="$(cd "$SCRIPT_DIR/../../clanker-courts-autoplayer/scripts" && pwd)"
  PYTHONPATH_VALUE="$PYTHONPATH_VALUE:$AUTOPLAYER_SCRIPT_DIR"
fi

run_with_python() {
  export PYTHONPATH="$PYTHONPATH_VALUE${PYTHONPATH:+:$PYTHONPATH}"
  exec "$1" -m clanker_courts_player.mcp_server_main "${@:2}"
}

is_compatible_python() {
  "$1" - <<'PY' >/dev/null 2>&1
import sys
if sys.version_info < (3, 11):
    raise SystemExit(1)
import pydantic
PY
}

if [[ -n "${PYTHON:-}" ]]; then
  if is_compatible_python "$PYTHON"; then
    run_with_python "$PYTHON" "$@"
  fi
  echo "PYTHON must point to Python 3.11+ with pydantic>=2,<3 installed" >&2
  exit 1
fi

if command -v python3 >/dev/null 2>&1 && is_compatible_python python3; then
  run_with_python python3 "$@"
fi

if command -v uv >/dev/null 2>&1; then
  export PYTHONPATH="$PYTHONPATH_VALUE${PYTHONPATH:+:$PYTHONPATH}"
  exec uv run --quiet --with "pydantic>=2,<3" --python ">=3.11" \
    python -m clanker_courts_player.mcp_server_main "$@"
fi

cat >&2 <<'EOF'
clanker-courts-mcp-server requires Python 3.11+ and pydantic>=2,<3.

Fix one of these before rerunning:
- use the full repo command: uv run clanker-courts-mcp-server ...
- install skill requirements: python3 -m pip install -r <skill-dir>/scripts/requirements.txt
- set PYTHON to a compatible interpreter with pydantic installed
EOF
exit 1
